{
  "version": "2.0",
  "project": "ecommerce-tech-store",
  "description": "B2C single-vendor tech store - FE + API Gateway + 6 backend services",
  "language": {
    "docs": "vi",
    "code": "en",
    "commit": "en"
  },
  "architecture": {
    "overview": "architecture/00-overview.md",
    "techStack": "architecture/01-tech-stack.md",
    "sequenceDiagrams": "architecture/02-sequence-diagrams.md",
    "classDiagrams": "architecture/03-class-diagrams.md",
    "frontend": "architecture/frontend.md",
    "services": {
      "apiGateway": "architecture/services/api-gateway.md",
      "user": "architecture/services/user-service.md",
      "product": "architecture/services/product-service.md",
      "order": "architecture/services/order-service.md",
      "payment": "architecture/services/payment-service.md",
      "inventory": "architecture/services/inventory-service.md",
      "notification": "architecture/services/notification-service.md"
    }
  },
  "strategy": {
    "businessOverview": "strategy/00-business-overview.md",
    "userJourneys": "strategy/01-user-journeys.md",
    "businessRules": "strategy/02-business-rules.md",
    "services": {
      "user": "strategy/services/user-business.md",
      "product": "strategy/services/product-business.md",
      "order": "strategy/services/order-business.md",
      "payment": "strategy/services/payment-business.md",
      "inventory": "strategy/services/inventory-business.md",
      "notification": "strategy/services/notification-business.md"
    }
  },
  "useCases": [
    {
      "id": "UC-AUTH",
      "name": "Xác thực người dùng (Register/Login/Logout/Reset)",
      "actor": "Customer, Guest",
      "services": ["user", "notification"],
      "service": "user-service",
      "ba": "ba/user-service/uc-auth.md",
      "ts": "technical-spec/user-service/ts-auth.md"
    },
    {
      "id": "UC-USER-PROFILE",
      "name": "Quản lý hồ sơ và sổ địa chỉ",
      "actor": "Customer",
      "services": ["user"],
      "service": "user-service",
      "ba": "ba/user-service/uc-user-profile.md",
      "ts": "technical-spec/user-service/ts-user-profile.md"
    },
    {
      "id": "UC-ADMIN-USER",
      "name": "Admin xem/khoá tài khoản người dùng",
      "actor": "Admin",
      "services": ["user", "notification"],
      "service": "user-service",
      "ba": "ba/user-service/uc-admin-user.md",
      "ts": "technical-spec/user-service/ts-admin-user.md"
    },
    {
      "id": "UC-PRODUCT-BROWSE",
      "name": "Duyệt/Tìm kiếm/Lọc/Xem chi tiết sản phẩm",
      "actor": "Customer, Guest",
      "services": ["product", "inventory"],
      "service": "product-service",
      "ba": "ba/product-service/uc-product-browse.md",
      "ts": "technical-spec/product-service/ts-product-browse.md"
    },
    {
      "id": "UC-PRODUCT-REVIEW",
      "name": "Viết và xem review/rating sản phẩm",
      "actor": "Customer",
      "services": ["product", "order"],
      "service": "product-service",
      "ba": "ba/product-service/uc-product-review.md",
      "ts": "technical-spec/product-service/ts-product-review.md"
    },
    {
      "id": "UC-ADMIN-PRODUCT",
      "name": "Admin quản lý product + category + inventory",
      "actor": "Admin",
      "services": ["product", "inventory"],
      "service": "product-service",
      "ba": "ba/product-service/uc-admin-product.md",
      "ts": "technical-spec/product-service/ts-admin-product.md"
    },
    {
      "id": "UC-CART",
      "name": "Quản lý giỏ hàng",
      "actor": "Customer",
      "services": ["order", "inventory", "product"],
      "service": "order-service",
      "ba": "ba/order-service/uc-cart.md",
      "ts": "technical-spec/order-service/ts-cart.md"
    },
    {
      "id": "UC-CHECKOUT-PAYMENT",
      "name": "Đặt hàng và thanh toán (VNPay/COD)",
      "actor": "Customer",
      "services": ["order", "payment", "inventory", "user", "notification"],
      "service": "order-service",
      "ba": "ba/order-service/uc-checkout-payment.md",
      "ts": "technical-spec/order-service/ts-checkout-payment.md"
    },
    {
      "id": "UC-ORDER-TRACKING",
      "name": "Lịch sử/Chi tiết/Tracking/Hủy đơn",
      "actor": "Customer",
      "services": ["order", "payment", "notification"],
      "service": "order-service",
      "ba": "ba/order-service/uc-order-tracking.md",
      "ts": "technical-spec/order-service/ts-order-tracking.md"
    },
    {
      "id": "UC-ADMIN-ORDER",
      "name": "Admin duyệt/cập nhật trạng thái đơn",
      "actor": "Admin",
      "services": ["order", "payment", "inventory", "notification"],
      "service": "order-service",
      "ba": "ba/order-service/uc-admin-order.md",
      "ts": "technical-spec/order-service/ts-admin-order.md"
    }
  ],
  "orderStates": [
    "PENDING",
    "PAID",
    "CONFIRMED",
    "PROCESSING",
    "SHIPPED",
    "DELIVERED",
    "COMPLETED",
    "CANCELLED",
    "REFUNDED"
  ],
  "paymentMethods": ["VNPAY", "COD"],
  "userRoles": ["CUSTOMER", "ADMIN"],
  "events": {
    "user": ["UserRegistered", "UserBlocked", "UserUnblocked", "PasswordResetRequested"],
    "order": ["OrderPlaced", "OrderStateChanged", "OrderDelivered", "OrderCancelled"],
    "payment": ["PaymentInitiated", "PaymentSucceeded", "PaymentFailed", "PaymentExpired"],
    "inventory": ["StockReserved", "StockReservationFailed", "StockCommitted", "StockReleased", "LowStockDetected"],
    "product": ["ProductCreated", "ProductUpdated", "ReviewPosted"],
    "notification": ["NotificationSent", "NotificationFailed"]
  },
  "apiVersionPrefix": "/api/v1"
}
